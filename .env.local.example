# Supabase — copie do painel: Settings > API
# Estas duas variáveis são públicas (expostas no cliente) — isso é esperado pelo Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# ⚠️  SEGREDO — nunca use o prefixo NEXT_PUBLIC_ nesta variável
# Usada APENAS em server-side: API Routes e Server Components
# Configure esta variável no painel da Vercel em: Settings > Environment Variables
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta
